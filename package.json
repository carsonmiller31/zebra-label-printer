{
  "name": "zebra-label-printer",
  "version": "0.2.1",
  "description": "Desktop app to design and print custom ZPL labels to a Zebra GX420d over the network.",
  "main": "electron/main.js",
  "homepage": "https://github.com/carsonmiller31/zebra-label-printer",
  "author": {
    "name": "Waveflow",
    "email": "carson@waveflow.dev"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "make-icon": "node scripts/make-icon.js",
    "dist:win": "npm run make-icon && electron-builder --win -p never",
    "dist": "npm run make-icon && electron-builder -p never",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.waveflow.zebralabelprinter",
    "productName": "Zebra Label Printer",
    "artifactName": "Zebra-Label-Printer-Setup-${version}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "carsonmiller31",
      "repo": "zebra-label-printer",
      "releaseType": "release"
    },
    "files": [
      "electron/**",
      "server.js",
      "public/**",
      "build/icon.png"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zebra Label Printer",
      "uninstallDisplayName": "Zebra Label Printer"
    }
  }
}
